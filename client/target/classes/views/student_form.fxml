<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox alignment="TOP_CENTER" spacing="20.0" styleClass="main-container" stylesheets="@../css/style.css" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.student.controllers.StudentController">
    <padding>
        <Insets bottom="30.0" left="40.0" right="40.0" top="30.0" />
    </padding>

    <Label styleClass="title-label" text="HỆ THỐNG ĐĂNG KÝ SINH VIÊN" />

    <GridPane hgap="15.0" vgap="15.0">
        <columnConstraints>
            <ColumnConstraints minWidth="120.0" />
            <ColumnConstraints hgrow="ALWAYS" minWidth="250.0" />
        </columnConstraints>

        <Label text="Họ và tên:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
        <TextField fx:id="txtName" promptText="Nhập họ và tên..." GridPane.columnIndex="1" GridPane.rowIndex="0" />

        <Label text="Mã sinh viên:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
        <TextField fx:id="txtStudentId" promptText="Nhập MSSV (VD: 25020082)..." GridPane.columnIndex="1" GridPane.rowIndex="1" />

        <Label text="Giới tính:" GridPane.columnIndex="0" GridPane.rowIndex="2" />
        <HBox alignment="CENTER_LEFT" spacing="20.0" GridPane.columnIndex="1" GridPane.rowIndex="2">
            <RadioButton selected="true" text="Nam">
                <toggleGroup>
                    <ToggleGroup fx:id="genderGroup" />
                </toggleGroup>
            </RadioButton>
            <RadioButton text="Nữ" toggleGroup="$genderGroup" />
        </HBox>

        <Label text="Dịch vụ bổ sung:" GridPane.columnIndex="0" GridPane.rowIndex="3" />
        <VBox spacing="8.0" GridPane.columnIndex="1" GridPane.rowIndex="3">
            <CheckBox fx:id="chkKtx" text="Đăng ký ở Ký túc xá" />
            <CheckBox fx:id="chkXe" text="Đăng ký vé gửi xe tháng" />
            <CheckBox fx:id="chkThuVien" text="Đăng ký thẻ Thư viện" />
        </VBox>
    </GridPane>

    <Label fx:id="lblMessage" text="">
        <font>
            <Font name="System Bold" size="13.0" />
        </font>
    </Label>

    <HBox alignment="CENTER" spacing="30.0" styleClass="action-box">
        <padding>
            <Insets top="10.0" />
        </padding>
        <Button onAction="#handleSubmit" styleClass="btn-primary" text="Xác nhận Đăng ký" />
        <Button onAction="#handleLoad" styleClass="btn-primary" style="-fx-background-color: #3498db;" text="Tải dữ liệu DB (Load)" />
        <Button onAction="#handleReset" styleClass="btn-secondary" text="Làm mới Form" />
    </HBox>
</VBox>